# Pint — environment variables
# Copy to .env (or set via `vercel env add` for production).

# OpenWeatherMap — free tier: 60 calls/min, 1M/month
# Sign up: https://openweathermap.org/api  (Current Weather Data)
# Used by: /api/breweries/weather-pick
OPENWEATHER_API_KEY=

# Google Places API — free tier: ~$200/mo credit
# https://console.cloud.google.com → Enable "Places API"
# Used by:
#   - /api/breweries/details   (reviews, photos, hours, price level)
#   - /api/scrape/city          (extra discovery source for multi-city scrape)
GOOGLE_PLACES_API_KEY=

# Untappd has a public API but tap lists are NOT supported — paid Business API only.
# We scrape the public Untappd venue page instead. No key required.
# (No env var needed.)
