{
  "cleanUrls": true,
  "functions": {
    "api/scrape/city.js": { "maxDuration": 300 },
    "api/breweries/taps.js": { "maxDuration": 30 },
    "api/breweries/weather-pick.js": { "maxDuration": 15 },
    "api/breweries/details.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/breweries.json",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ]
}
